From 476b855c8d4606e75548b8f774a9c4ffe7897e32 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Wed, 20 May 2026 17:02:56 +0200
Subject: [PATCH] Add missing QML module dependencies to Qt.labs.qmlmodels

Fixes Alligator APKs missing Qt.labs.qmlmodels and thus failing to start.
---
 src/components/CMakeLists.txt | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/components/CMakeLists.txt b/src/components/CMakeLists.txt
index 40249340..41f9212b 100644
--- a/src/components/CMakeLists.txt
+++ b/src/components/CMakeLists.txt
@@ -62,7 +62,7 @@ ecm_add_qml_module(componentslabsplugin
     URI "org.kde.kirigamiaddons.labs.components"
     VERSION 1.0
     GENERATE_PLUGIN_SOURCE
-    DEPENDENCIES org.kde.kirigamiaddons.components QtMultimedia
+    DEPENDENCIES org.kde.kirigamiaddons.components QtMultimedia Qt.labs.qmlmodels
 )
 
 ecm_generate_qdoc(componentslabsplugin kirigamiaddonscomponents.qdocconf)
@@ -97,6 +97,7 @@ ecm_add_qml_module(componentsplugin
     GENERATE_PLUGIN_SOURCE
     DEPENDENCIES
         org.kde.kirigami
+        Qt.labs.qmlmodels
 )
 
 target_sources(componentsplugin PRIVATE
-- 
GitLab

