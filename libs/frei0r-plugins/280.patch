From 56113b982f90cb1b30c723c4b599941008bf0569 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Julius=20K=C3=BCnzel?= <julius.kuenzel@kde.org>
Date: Sun, 7 Jun 2026 11:52:30 +0200
Subject: [PATCH] fix(msvc): put math.h after _USE_MATH_DEFINES again

The _USE_MATH_DEFINES is useless otherwise and MSVC does not know M_PI (error C2065: 'M_PI': undeclared identifier)
---
 src/filter/camerashake/camerashake.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/filter/camerashake/camerashake.cpp b/src/filter/camerashake/camerashake.cpp
index 409af1a1..969c9e7f 100644
--- a/src/filter/camerashake/camerashake.cpp
+++ b/src/filter/camerashake/camerashake.cpp
@@ -17,12 +17,12 @@
  * Foundation, Inc., 675 Mass Ave, Cambridge, MA 02139, USA.
  */
 
-#include <math.h>
 #include <stdlib.h>
 #include <string.h>
 #if defined(_MSC_VER)
 #define _USE_MATH_DEFINES
 #endif
+#include <math.h>
 
 extern "C" {
     #include <frei0r.h>
