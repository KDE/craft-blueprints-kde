From 6f3c8a9f223b6b83e2b55cea33a3fd3db26eb533 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Julius=20K=C3=BCnzel?= <julius.kuenzel@kde.org>
Date: Sun, 7 Jun 2026 12:21:48 +0200
Subject: [PATCH] fix(msvc): define parameter name in colorenhance

MSVC 2019 fails to build without the parameter name with error C2055: expected formal parameter list, not a type list

But also Clang complains: (-Wc23-extensions) Omitting the parameter name in a function definition is a C23 extension

Fixup for #259
---
 src/filter/colorenhance/colorenhance.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/filter/colorenhance/colorenhance.c b/src/filter/colorenhance/colorenhance.c
index dca91394..72de5241 100644
--- a/src/filter/colorenhance/colorenhance.c
+++ b/src/filter/colorenhance/colorenhance.c
@@ -157,7 +157,7 @@ void f0r_get_param_value(f0r_instance_t instance, f0r_param_t param, int param_i
     }
 }
 
-void f0r_update(f0r_instance_t instance, double, const uint32_t* inframe, uint32_t* outframe) 
+void f0r_update(f0r_instance_t instance, double time, const uint32_t* inframe, uint32_t* outframe)
 {
     colorenhance_t* inst = (colorenhance_t*)instance;
     const uint8_t* input = (const uint8_t*)inframe;
